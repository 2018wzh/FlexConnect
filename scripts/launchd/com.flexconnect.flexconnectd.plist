<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.flexconnect.flexconnectd</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/flexconnectd</string>
    <string>--socket</string>
    <string>/var/run/flexconnect.sock</string>
    <string>--state</string>
    <string>/usr/local/var/flexconnect/state.json</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/usr/local/var/log/flexconnect.log</string>
  <key>StandardErrorPath</key>
  <string>/usr/local/var/log/flexconnect.log</string>
</dict>
</plist>
